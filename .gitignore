# ============================================================================
# HousingAI Portal — Root .gitignore
# Covers: ml-model (Python) · backend-python (Python) · backend-java (Java/Maven)
#         frontend (Next.js / TypeScript)
# ============================================================================

# ── Environment files ────────────────────────────────────────────────────────
# Actual env files (contain secrets / local overrides) — never commit these
.env
.env.local
.env.production
.env.production.local
.env.staging
.env.test.local
# .env.example and .env.local.example are intentionally NOT ignored —
# they are the committed templates

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# JetBrains IDEs (IntelliJ, PyCharm, etc.)
.idea/
*.iml
*.ipr
*.iws
out/

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# Eclipse
.classpath
.project
.settings/
.factorypath

# ── Python (ml-model + backend-python) ───────────────────────────────────────
# Byte-compiled / optimised / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Virtual environments
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/
share/python-wheels/
MANIFEST

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/

# ── ML Artifacts (ml-model) ──────────────────────────────────────────────────
# Trained model binary — large binary, rebuilt by train.py
ml-model/app/model.joblib

# Model metadata — generated by train.py, not hand-edited
ml-model/app/model_meta.json

# Training dataset — source of truth kept outside VCS or tracked via DVC
# Uncomment the line below if you move the CSV out of the repo:
# ml-model/House_Price_Dataset.csv

# ── Python Backend (backend-python) ──────────────────────────────────────────
# SQLite history database — runtime data, not source
backend-python/history.db
backend-python/*.db
backend-python/*.sqlite
backend-python/*.sqlite3

# ── Java / Maven (backend-java) ──────────────────────────────────────────────
# Maven build output
backend-java/target/

# Compiled class files (if ever outside target/)
*.class

# Package files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Maven wrapper downloads
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/maven-wrapper.jar
!**/src/test/**/maven-wrapper.jar

# Spring Boot DevTools restart trigger
backend-java/.reloadtrigger

# Gradle (in case project ever gains a Gradle build)
.gradle/
gradle-app.setting
!gradle-wrapper.jar

# ── Frontend (Next.js / Node) ─────────────────────────────────────────────────
# Dependencies
frontend/node_modules/
node_modules/

# Next.js build output
frontend/.next/
frontend/out/

# Vercel deployment
.vercel/

# TypeScript incremental build info
frontend/tsconfig.tsbuildinfo
tsconfig.tsbuildinfo

# ESLint cache
frontend/.eslintcache
.eslintcache

# Parcel cache
.parcel-cache/

# Storybook
frontend/storybook-static/

# Testing
frontend/coverage/
frontend/.nyc_output/

# PWA / next-pwa generated files
frontend/public/sw.js
frontend/public/workbox-*.js
frontend/public/worker-*.js
frontend/public/sw.js.map
frontend/public/workbox-*.js.map

# ── Docker ───────────────────────────────────────────────────────────────────
# Don't ignore Dockerfiles or docker-compose.yml — those are source
# Do ignore any local override compose files
docker-compose.override.yml

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Misc ─────────────────────────────────────────────────────────────────────
# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Secrets / certificates accidentally dropped in repo
*.pem
*.key
*.p12
*.pfx
*.crt
*.cert
